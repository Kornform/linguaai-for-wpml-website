---
---

<section class="section">
  <div class="container mx-auto px-6">
    <div class="cta-wrap relative overflow-hidden rounded-3xl p-12 lg:p-16 text-center">

      <!-- Background glow -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full opacity-30"
          style="background: radial-gradient(ellipse, rgba(99,102,241,0.3) 0%, transparent 70%);">
        </div>
      </div>

      <!-- Grid overlay -->
      <div class="absolute inset-0 pointer-events-none opacity-40"
        style="background-image: linear-gradient(rgba(99,102,241,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,0.05) 1px, transparent 1px); background-size: 40px 40px;">
      </div>

      <div class="relative">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-primary-light mb-5">Get Started</p>
        <h2 class="text-3xl lg:text-5xl font-bold text-white mb-5 tracking-tight leading-[1.1]">
          Start translating today.
        </h2>
        <p class="text-slate-400 text-lg mb-10 max-w-[480px] mx-auto leading-relaxed">
          Free to start. Pro from €49/year. You own your API keys — no lock-in, no per-word fees.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="#pricing" class="cta-primary-lg">
            Get Pro — from €49/year
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="https://wordpress.org" target="_blank" rel="noopener" class="cta-secondary-lg">
            Download Free on WordPress.org
          </a>
        </div>

        <p class="mt-8 text-xs text-slate-600">
          WordPress 6.2+ · WPML required · GPLv2 License
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-wrap {
    background: var(--card);
    border: 1px solid var(--border);
  }

  .cta-primary-lg {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-color: var(--color-accent);
    color: #ffffff;
    font-weight: 600;
    font-size: 15px;
    padding: 12px 24px;
    border-radius: var(--radius-xl);
    transition: all var(--transition-base);
    box-shadow: 0 0 32px rgba(99, 102, 241, 0.25);
  }
  .cta-primary-lg:hover {
    background-color: var(--color-accent-hover);
    box-shadow: 0 0 48px rgba(99, 102, 241, 0.4);
    transform: translateY(-1px);
  }

  .cta-secondary-lg {
    display: inline-flex;
    align-items: center;
    color: #94a3b8;
    font-weight: 500;
    font-size: 15px;
    padding: 12px 24px;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border-subtle);
    background-color: rgba(255, 255, 255, 0.03);
    transition: all var(--transition-base);
  }
  .cta-secondary-lg:hover {
    color: #ffffff;
    border-color: #4b5563;
    background-color: rgba(255, 255, 255, 0.06);
  }
</style>
