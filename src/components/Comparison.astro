---
const rows = [
  { feature: 'AI Provider', linguaai: 'OpenAI + Anthropic', wpml: 'OpenAI (via WPML)', deepl: 'DeepL only' },
  { feature: 'Background processing', linguaai: true, wpml: false, deepl: false },
  { feature: 'Custom prompt control', linguaai: true, wpml: false, deepl: false },
  { feature: 'Glossary / Terminology', linguaai: true, wpml: false, deepl: 'Limited' },
  { feature: 'Translation Profiles', linguaai: true, wpml: false, deepl: false },
  { feature: 'Full cost transparency', linguaai: true, wpml: false, deepl: false },
  { feature: 'ACF Integration', linguaai: true, wpml: false, deepl: false },
  { feature: 'Page Builder support', linguaai: 'Bricks + Elementor', wpml: false, deepl: false },
  { feature: 'Billing model', linguaai: 'API costs only', wpml: '~€0.07/word', deepl: 'Subscription' },
  { feature: 'License price', linguaai: '€49–99/year', wpml: 'Per word, no cap', deepl: 'Subscription' },
];

function renderCell(value: string | boolean, highlight = false) {
  if (value === true) {
    return `<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green-500/10 border border-green-500/20 text-green-400">
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
        <path d="M2 5l2.2 2.2L8 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>`;
  }
  if (value === false) {
    return `<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-red-500/8 border border-red-500/15 text-red-400/70">
      <svg width="8" height="8" viewBox="0 0 8 8" fill="none">
        <path d="M1.5 1.5l5 5M6.5 1.5l-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    </span>`;
  }
  return `<span class="${highlight ? 'text-slate-200 font-medium' : 'text-slate-500'} text-xs">${value}</span>`;
}
---

<section class="section" id="comparison">
  <div class="container mx-auto px-6">

    <div class="text-center mb-12">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-primary-light mb-4">Comparison</p>
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4 tracking-tight">
        See how LinguaAI compares
      </h2>
      <p class="text-slate-500 max-w-[440px] mx-auto leading-relaxed text-sm">
        A direct feature and cost comparison with the most common alternatives for WPML users.
      </p>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-border">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border">
            <th class="th-base text-left text-slate-500 font-medium w-[28%]">Feature</th>
            <th class="th-base text-center bg-primary/[0.07] border-x border-primary/10">
              <div class="flex flex-col items-center gap-1">
                <span class="text-primary-light font-semibold text-sm">LinguaAI Pro</span>
                <span class="text-[10px] text-slate-500 font-normal">from €49/year</span>
              </div>
            </th>
            <th class="th-base text-center">
              <div class="flex flex-col items-center gap-1">
                <span class="text-slate-400 font-medium">WPML Translation</span>
                <span class="text-[10px] text-slate-600 font-normal">~€0.07/word</span>
              </div>
            </th>
            <th class="th-base text-center">
              <div class="flex flex-col items-center gap-1">
                <span class="text-slate-400 font-medium">DeepL for WPML</span>
                <span class="text-[10px] text-slate-600 font-normal">Subscription</span>
              </div>
            </th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class={`border-b border-border/50 ${i % 2 !== 0 ? 'bg-white/[0.01]' : ''}`}>
              <td class="td-base text-slate-400">{row.feature}</td>
              <td class="td-base text-center bg-primary/[0.03] border-x border-primary/[0.08]">
                <Fragment set:html={renderCell(row.linguaai, true)} />
              </td>
              <td class="td-base text-center">
                <Fragment set:html={renderCell(row.wpml)} />
              </td>
              <td class="td-base text-center">
                <Fragment set:html={renderCell(row.deepl)} />
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Cost callout -->
    <div class="mt-6 p-5 rounded-xl border border-green-500/20 bg-green-500/[0.04] flex items-start gap-3">
      <svg class="flex-shrink-0 mt-0.5 text-green-400" width="18" height="18" viewBox="0 0 18 18" fill="none">
        <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.3"/>
        <path d="M5.5 9l2.5 2.5L12.5 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-sm text-slate-400 leading-relaxed">
        <strong class="text-green-400">Real numbers:</strong> Translating 10,000 words with WPML Translation Services costs ~€700. With LinguaAI Pro + GPT-4o Mini, the same job costs around <strong class="text-slate-300">€0.50–5 in API fees — plus €49/year</strong> for the plugin license.
      </p>
    </div>

  </div>
</section>

<style>
  .th-base {
    padding: 16px 20px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .td-base {
    padding: 12px 20px;
  }
</style>
