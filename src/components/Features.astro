---
const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.4"/><path d="M6.5 10h3M10 10l2.5-2.5M10 10l2.5 2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    label: 'AI & Providers',
    title: 'OpenAI and Anthropic — both.',
    description: 'Choose between GPT-5, GPT-4o and Claude Haiku, Sonnet, Opus. Switch providers in settings. No other WPML AI plugin offers both.',
    highlight: 'GPT-5 · GPT-4o · Claude Haiku · Sonnet · Opus',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 3v4M10 13v4M3 10h4M13 10h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.4"/></svg>`,
    label: 'Architecture',
    title: 'Background processing. No timeouts.',
    description: 'Translations run via OpenAI\'s Responses API — asynchronous, non-blocking. You click Translate, close the tab, and the plugin handles the rest.',
    highlight: 'Async · WP Cron polling · No HTTP timeout',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 5h12M4 8h8M4 11h10M4 14h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    label: 'Terminology',
    title: 'Glossary — your terms, every time.',
    description: 'Define product names, brand terms and technical vocabulary in CSV or JSON. Global or per language pair. Injected automatically into every prompt.',
    highlight: 'CSV · JSON · Global + per language pair',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.4"/><path d="M7 10h6M10 7v6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    label: 'Workflow',
    title: 'Translation Profiles.',
    description: 'Bundle model + prompt template + glossary into a reusable preset. "Quick Draft" for blogs, "Precise + Full" for product pages. One click, consistent results.',
    highlight: 'Model · Prompt · Glossary — as one preset',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 14l4-4 3 3 3-5 4 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    label: 'Cost Control',
    title: 'Full cost transparency — per job.',
    description: 'See input, output and cached token counts for every translation. Open a breakdown modal to see how much each component (glossary, prompt, content) cost.',
    highlight: 'You pay OpenAI/Anthropic directly. No markup.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M6 4h8a2 2 0 012 2v8a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2z" stroke="currentColor" stroke-width="1.4"/><path d="M8 9h4M8 12h2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
    label: 'Prompt Control',
    title: 'Your instructions. Your output.',
    description: 'Write a custom system prompt or pick from reusable Prompt Templates per content type. Adjust per job. No code needed — everything in the WordPress admin.',
    highlight: 'System Prompt · Templates · Per-job override',
  },
];
---

<section class="section" id="features">
  <div class="container mx-auto px-6">

    <div class="text-center mb-16">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-primary-light mb-4">Features</p>
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4 tracking-tight">
        Everything you need to translate at scale
      </h2>
      <p class="text-slate-500 max-w-[520px] mx-auto leading-relaxed">
        Not just a wrapper around an AI API. LinguaAI is a complete translation workflow — built specifically for WPML.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((f) => (
        <div class="feature-card group">
          <div class="flex items-start gap-4 mb-4">
            <div class="icon-wrap text-primary-light flex-shrink-0" set:html={f.icon} />
            <span class="text-[10px] font-semibold uppercase tracking-[0.12em] text-slate-600 pt-1">{f.label}</span>
          </div>
          <h3 class="text-white font-semibold text-[15px] mb-2 leading-snug">{f.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed mb-4">{f.description}</p>
          <div class="mt-auto pt-4 border-t border-border/50">
            <span class="text-[11px] text-slate-600 font-mono">{f.highlight}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Additional feature list (smaller, below grid) -->
    <div class="mt-10 p-6 rounded-2xl border border-border bg-surface/40">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600 mb-4">Also included</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {[
          'ACF field translation',
          'Bricks Builder support',
          'Elementor support',
          'Taxonomy term translation',
          'Translate Again (re-translate)',
          '3-second cancel window',
          'Translation history log',
          'Diagnostics & health checks',
        ].map((item) => (
          <div class="flex items-center gap-2 text-sm text-slate-400">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <circle cx="7" cy="7" r="5.5" stroke="#4ade80" stroke-width="1.3"/>
              <path d="M4.5 7l1.8 1.8L9.5 5" stroke="#4ade80" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {item}
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .feature-card {
    padding: 24px;
    display: flex;
    flex-direction: column;
    border-radius: 20px;
    background: var(--card);
    border: 1px solid var(--border);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .feature-card:hover {
    border-color: rgba(99, 102, 241, 0.3);
    box-shadow: 0 0 24px rgba(99, 102, 241, 0.08);
  }

  .icon-wrap {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.15);
  }
</style>
