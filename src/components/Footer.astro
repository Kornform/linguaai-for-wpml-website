---
const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div class="container mx-auto px-6 pt-14 pb-8">

    <!-- Main grid: brand + 2 link columns -->
    <div class="grid grid-cols-2 md:grid-cols-[1.8fr_1fr_1fr] gap-x-8 gap-y-10 mb-12">

      <!-- Brand — spans full width on mobile -->
      <div class="col-span-2 md:col-span-1 flex flex-col gap-5">
        <a href="/" class="flex items-center gap-2.5 w-fit group">
          <div class="w-7 h-7 rounded-lg bg-primary flex items-center justify-center flex-shrink-0">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M2 4h12M2 8h8M2 12h10" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
              <circle cx="13" cy="8" r="2.5" fill="white" opacity="0.9"/>
            </svg>
          </div>
          <span class="font-semibold text-white text-[14px] leading-none">
            LinguaAI
            <span class="text-slate-500 font-normal"> for WPML</span>
          </span>
        </a>

        <p class="text-sm text-slate-500 leading-relaxed max-w-[280px]">
          AI-powered WordPress translation for WPML sites. Background processing, glossary control, full cost transparency.
        </p>

        <p class="text-xs text-slate-600">
          Made by{' '}
          <a
            href="https://maxkorn.de"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-500 hover:text-white transition-colors underline underline-offset-2 decoration-slate-700 hover:decoration-slate-400"
          >
            Max Korn
          </a>
        </p>
      </div>

      <!-- Product links -->
      <div class="flex flex-col gap-3">
        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-600 mb-1">Product</p>
        <a href="#features" class="footer-link">Features</a>
        <a href="#pricing" class="footer-link">Pricing</a>
        <a href="#comparison" class="footer-link">Comparison</a>
        <a href="/changelog" class="footer-link">Changelog</a>
        <a href="/docs" class="footer-link">Documentation</a>
      </div>

      <!-- Account links -->
      <div class="flex flex-col gap-3">
        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-600 mb-1">Account</p>
        <a href="/login" class="footer-link">Sign in</a>
        <a href="/login" class="footer-link">Create account</a>
        <a href="/dashboard" class="footer-link">Dashboard</a>
        <a
          href="https://github.com/Kornform/linguaai-for-wpml-plugin"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-link inline-flex items-center gap-1.5"
        >
          GitHub
          <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
            <path d="M2.5 8.5l6-6M8.5 2.5H4M8.5 2.5v4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-border/40 flex flex-col gap-3">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 text-xs text-slate-600">
        <p>© {year} Max Korn. Licensed under GPLv2 or later.</p>
        <p>Not affiliated with OnTheGoSystems (WPML), OpenAI, or Anthropic.</p>
      </div>
      <p class="text-xs text-slate-700 leading-relaxed">
        All API costs are billed directly by the respective provider (OpenAI / Anthropic) — not by LinguaAI.
        Displayed token costs are estimates based on published pricing and may vary.
      </p>
    </div>

  </div>
</footer>

<style>
  .footer-link {
    font-size: 0.875rem;
    color: #64748b;
    transition: color 0.15s ease;
    width: fit-content;
  }

  .footer-link:hover {
    color: #f1f5f9;
  }
</style>
