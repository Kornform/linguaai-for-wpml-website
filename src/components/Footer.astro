---
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-surface/30">
  <div class="container mx-auto px-6 py-12">

    <div class="grid md:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2.5 mb-4 group w-fit">
          <div class="w-7 h-7 rounded-lg bg-primary flex items-center justify-center">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M2 4h12M2 8h8M2 12h10" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
              <circle cx="13" cy="8" r="2.5" fill="white" opacity="0.9"/>
            </svg>
          </div>
          <span class="font-semibold text-white text-[14px]">LinguaAI <span class="text-slate-500 font-normal">for WPML</span></span>
        </a>
        <p class="text-sm text-slate-500 leading-relaxed max-w-[300px]">
          AI-powered WordPress translation for WPML sites. Background processing, glossary control, full cost transparency.
        </p>
        <p class="mt-4 text-xs text-slate-600">
          Made by <a href="https://maxkorn.de" target="_blank" rel="noopener" class="text-slate-500 hover:text-white transition-colors">Max Korn</a>
        </p>
      </div>

      <!-- Product -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600 mb-4">Product</p>
        <ul class="space-y-2.5">
          <li><a href="#features" class="footer-link">Features</a></li>
          <li><a href="#pricing" class="footer-link">Pricing</a></li>
          <li><a href="#comparison" class="footer-link">Comparison</a></li>
          <li><a href="/changelog" class="footer-link">Changelog</a></li>
          <li><a href="/docs" class="footer-link">Documentation</a></li>
        </ul>
      </div>

      <!-- Account -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600 mb-4">Account</p>
        <ul class="space-y-2.5">
          <li><a href="/login" class="footer-link">Sign in</a></li>
          <li><a href="/login" class="footer-link">Create account</a></li>
          <li><a href="/dashboard" class="footer-link">Dashboard</a></li>
          <li>
            <a href="https://github.com/Kornform/linguaai-for-wpml-plugin" target="_blank" rel="noopener" class="footer-link flex items-center gap-1.5">
              GitHub
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                <path d="M2.5 7.5l5-5M7.5 2.5H3M7.5 2.5v4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-border/50 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-600">
      <p>© {year} Max Korn. LinguaAI for WPML is licensed under GPLv2 or later.</p>
      <p class="text-center sm:text-right leading-relaxed">
        LinguaAI is not affiliated with or endorsed by OnTheGoSystems (WPML), OpenAI, or Anthropic.
        All API costs are billed directly by the respective provider.
      </p>
    </div>

  </div>
</footer>

<style>
  .footer-link {
    @apply text-sm text-slate-500 hover:text-white transition-colors;
  }
</style>
